## RPC ФУНКЦІЇ — ПОВНИЙ СПИСОК

### Клієнтські (викликає Flutter)

// Створити бронювання
// Помилки: UNAUTHORIZED, SLOT_CANCELLED, SLOT_IN_PAST, NO_SEATS,
//          SUB_NOT_FOUND, SUB_INACTIVE, SUB_EXPIRED, NO_VISITS_LEFT,
//          TIME_CONFLICT, ALREADY_BOOKED
await supabase.rpc('rpc_create_booking', params: {
  'p_slot_id': slotId,        // UUID String
  'p_subscription_id': subId, // UUID String
});

// Скасувати бронювання
// Помилки: NOT_FOUND, WRONG_STATUS, TRAINING_ALREADY_STARTED
// Повертає: {success, visits_refunded, cancellation_hours, message_uk}
await supabase.rpc('rpc_cancel_booking', params: {
  'p_booking_id': bookingId,
});

// Стати в чергу
// Повертає: {success, waitlist_id, position}
await supabase.rpc('rpc_join_waitlist', params: {
  'p_slot_id': slotId,
  'p_subscription_id': subId,
});

// Вийти з черги
await supabase.rpc('rpc_leave_waitlist', params: {
  'p_waitlist_id': waitlistId,
});

// Підтвердити просування з черги
// Помилки: NOT_FOUND, NOT_PROMOTED, OFFER_EXPIRED
await supabase.rpc('rpc_confirm_waitlist_promotion', params: {
  'p_waitlist_id': waitlistId,
});

// Зареєструвати FCM токен (викликати при кожному логіні)
await supabase.rpc('rpc_upsert_device_token', params: {
  'p_fcm_token': token,
  'p_platform': 'android', // або 'ios'
  'p_app_version': '1.0.0',
});

### Адмінські — НЕ ВИКЛИКАТИ З FLUTTER (тільки Supabase Studio)

rpc_assign_subscription(p_client_id, p_plan_id, p_notes?, p_payment_method?, p_amount_uah?)
