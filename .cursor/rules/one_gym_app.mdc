## ШАБЛОН МОДЕЛІ

class ScheduleSlot {
  final String id;
  final String trainingTypeId;
  final String? trainerId;
  final DateTime startsAt;  // завжди UTC
  final DateTime endsAt;    // завжди UTC
  final int capacity;
  final int bookedCount;
  final int waitlistLimit;
  final bool isCancelled;

  factory ScheduleSlot.fromJson(Map<String, dynamic> json) => ScheduleSlot(
    id: json['id'] as String,
    trainingTypeId: json['training_type_id'] as String,
    trainerId: json['trainer_id'] as String?,
    startsAt: DateTime.parse(json['starts_at'] as String).toUtc(),
    endsAt: DateTime.parse(json['ends_at'] as String).toUtc(),
    capacity: json['capacity'] as int,
    bookedCount: json['booked_count'] as int,
    waitlistLimit: json['waitlist_limit'] as int,
    isCancelled: json['is_cancelled'] as bool,
  );

  bool get isFull => bookedCount >= capacity;
  int get seatsLeft => capacity - bookedCount;
  DateTime get startsAtLocal => startsAt.toLocal();
}

