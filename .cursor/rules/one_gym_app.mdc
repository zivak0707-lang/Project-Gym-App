## ШАБЛОН ОБРОБКИ ПОМИЛОК RPC

Future<void> createBooking(String slotId, String subId) async {
  try {
    final result = await supabase.rpc('rpc_create_booking', params: {
      'p_slot_id': slotId,
      'p_subscription_id': subId,
    });
    if (result['success'] == true) {
      // успіх — result['booking_id']
    } else {
      throw AppException(_mapRpcError(result['error'] as String));
    }
  } on PostgrestException catch (e) {
    throw AppException('DB error: ${e.message}');
  }
}

String _mapRpcError(String code) => switch (code) {
  'NO_SEATS'        => 'Місць немає. Записатись в чергу?',
  'SUB_EXPIRED'     => 'Абонемент закінчився',
  'SUB_INACTIVE'    => 'Абонемент не активний',
  'NO_VISITS_LEFT'  => 'Закінчились відвідування',
  'TIME_CONFLICT'   => 'У вас вже є тренування в цей час',
  'SLOT_IN_PAST'    => 'Це тренування вже відбулось',
  'SLOT_CANCELLED'  => 'Тренування скасовано клубом',
  'ALREADY_BOOKED'  => 'Ви вже записані на це тренування',
  _                 => 'Щось пішло не так. Спробуйте ще раз',
};

